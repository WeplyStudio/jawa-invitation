rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /rsvps/{document} {
      allow read, write, delete: if true;
    }
    match /wishes/{document} {
      allow read, write, delete: if true;
    }
    match /broadcasts/{document} {
      allow read, write, delete: if true;
    }
  }
}
